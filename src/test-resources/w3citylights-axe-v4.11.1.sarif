        {
          "ruleId": "scope-attr-valid",
          "ruleIndex": 76,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure the scope attribute is used correctly on tables."
          },
          "locations": []
        },
        {
          "ruleId": "scrollable-region-focusable",
          "ruleIndex": 77,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure elements that have scrollable content are accessible by keyboard."
          },
          "locations": []
        },
        {
          "ruleId": "select-name",
          "ruleIndex": 78,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure select element has an accessible name."
          },
          "locations": []
        },
        {
          "ruleId": "server-side-image-map",
          "ruleIndex": 79,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure that server-side image maps are not used."
          },
          "locations": []
        },
        {
          "ruleId": "skip-link",
          "ruleIndex": 80,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure all skip links have a focusable target."
          },
          "locations": []
        },
        {
          "ruleId": "summary-name",
          "ruleIndex": 81,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure summary elements have discernible text."
          },
          "locations": []
        },
        {
          "ruleId": "svg-img-alt",
          "ruleIndex": 82,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure <svg> elements with an img, graphics-document or graphics-symbol role have accessible text."
          },
          "locations": []
        },
        {
          "ruleId": "tabindex",
          "ruleIndex": 83,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure tabindex attribute values are not greater than 0."
          },
          "locations": []
        },
        {
          "ruleId": "table-duplicate-name",
          "ruleIndex": 84,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure the <caption> element does not contain the same text as the summary attribute."
          },
          "locations": []
        },
        {
          "ruleId": "td-headers-attr",
          "ruleIndex": 85,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure that each cell in a table that uses the headers attribute refers only to other <th> elements in that table."
          },
          "locations": []
        },
        {
          "ruleId": "th-has-data-cells",
          "ruleIndex": 86,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure that <th> elements and elements with role=columnheader/rowheader have data cells they describe."
          },
          "locations": []
        },
        {
          "ruleId": "valid-lang",
          "ruleIndex": 87,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure lang attributes have valid values."
          },
          "locations": []
        },
        {
          "ruleId": "video-caption",
          "ruleIndex": 88,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure <video> elements have captions."
          },
          "locations": []
        },
        {
          "ruleId": "no-autoplay-audio",
          "ruleIndex": 70,
          "kind": "notApplicable",
          "level": "none",
          "message": {
            "text": "Ensure <video> or <audio> elements do not autoplay audio for more than 3 seconds without a control mechanism to stop or mute the audio."
          },
          "locations": []
        }
      ],
